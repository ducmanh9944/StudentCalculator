<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="16dp">

    <!-- Display Area -->
    <TextView
        android:id="@+id/tv_expression"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="end"
        android:hint="0"
        android:maxLines="2"
        android:textColor="@android:color/black"
        android:textSize="48sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="125 + 25" />

    <TextView
        android:id="@+id/tv_result"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:textColor="#757575"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_expression"
        tools:text="150" />

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#EEEEEE"
        app:layout_constraintTop_toBottomOf="@id/tv_result" />

    <!-- Button Grid -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider">

        <androidx.constraintlayout.helper.widget.Flow
            android:id="@+id/flow_buttons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:constraint_referenced_ids="btn_parentheses,btn_percent,btn_del,btn_ac,btn_sqr,btn_pow,btn_sqrt,btn_divide,btn_7,btn_8,btn_9,btn_multiply,btn_4,btn_5,btn_6,btn_minus,btn_1,btn_2,btn_3,btn_plus,btn_sign,btn_0,btn_dot,btn_equals"
            app:flow_horizontalGap="12dp"
            app:flow_maxElementsWrap="4"
            app:flow_verticalGap="12dp"
            app:flow_wrapMode="aligned" />

        <!-- Action Buttons (White background) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ac"
            style="@style/Widget.App.Button.Circular.Action"
            android:text="AC"
            android:textColor="#FF5252" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_del"
            style="@style/Widget.App.Button.Circular.Action"
            android:text="DEL"
            android:textColor="#FF5252" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_parentheses"
            style="@style/Widget.App.Button.Circular.Action"
            android:text="( )" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_percent"
            style="@style/Widget.App.Button.Circular.Action"
            android:text="%" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sqr"
            style="@style/Widget.App.Button.Circular.Action"
            android:text="x²" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pow"
            style="@style/Widget.App.Button.Circular.Action"
            android:text="xʸ" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sqrt"
            style="@style/Widget.App.Button.Circular.Action"
            android:text="√" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_divide"
            style="@style/Widget.App.Button.Circular.Action"
            android:text="÷"
            android:textSize="24sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_multiply"
            style="@style/Widget.App.Button.Circular.Action"
            android:text="×"
            android:textSize="24sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_minus"
            style="@style/Widget.App.Button.Circular.Action"
            android:text="-"
            android:textSize="24sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_plus"
            style="@style/Widget.App.Button.Circular.Action"
            android:text="+"
            android:textSize="24sp" />

        <!-- Equals Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_equals"
            style="@style/Widget.App.Button.Circular.Equals"
            android:text="=" />

        <!-- Numeric Buttons (Light Gray) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_7"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="7" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_8"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_9"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="9" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_4"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_5"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_6"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="6" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_1"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_2"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_3"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sign"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="+/-"
            android:textSize="18sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_0"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dot"
            style="@style/Widget.App.Button.Circular.Numeric"
            android:text="." />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>