<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.StudentCalculator" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#1976D2</item>
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.StudentCalculator" parent="Base.Theme.StudentCalculator" />

    <!-- Common Button Base -->
    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="elevation">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <!-- Portrait Styles  -->
    <style name="Widget.App.Button.Circular.Numeric" parent="Widget.App.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="backgroundTint">#F0F0F4</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="cornerRadius">100dp</item>
        <item name="layout_constraintDimensionRatio">1:1</item>
        <item name="android:textSize">22sp</item>
    </style>
    <style name="Widget.App.Button.Circular.Action" parent="Widget.App.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="backgroundTint">#F0F0F4</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="strokeColor">#EEEEEE</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">100dp</item>
        <item name="layout_constraintDimensionRatio">1:1</item>
        <item name="android:textSize">18sp</item>
    </style>
    <style name="Widget.App.Button.Circular.Equals" parent="Widget.App.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="cornerRadius">100dp</item>
        <item name="layout_constraintDimensionRatio">1:1</item>
        <item name="android:textSize">24sp</item>
    </style>

    <!-- Landscape Styles -->
    <style name="Widget.App.Button.Rect" parent="Widget.App.Button">
        <item name="cornerRadius">10dp</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/calc_button_height_rect</item>
    </style>
    <style name="Widget.App.Button.Rect.Numeric" parent="Widget.App.Button.Rect">
        <item name="backgroundTint">#F0F0F4</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">18sp</item>
    </style>
    <style name="Widget.App.Button.Rect.Action" parent="Widget.App.Button.Rect">
        <item name="backgroundTint">#F0F0F4</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="strokeColor">#EEEEEE</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="Widget.App.Button.Rect.Equals" parent="Widget.App.Button.Rect">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">20sp</item>
    </style>
</resources>